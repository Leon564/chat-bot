OPENAI_API_KEY = sk-xxx
GEMINI_API_KEY= example

MAX_LENGTH_RESPONSE = 200
CONTEXT_LENGTH = 5
RESPONSE_DELAY = 1000
USE_MEMORY = true  # true/false - Activar sistema de memoria inteligente para recordar preferencias del usuario

# Configuración del servicio de subida de archivos
# catbox = permanente, litterbox = temporal (se borra automáticamente)
UPLOAD_SERVICE = catbox  # catbox/litterbox
LITTERBOX_EXPIRY = 1h    # Tiempo de expiración para litterbox: 1h, 12h, 24h, 72h

# Configuración de música
MAX_SONG_DURATION = 8    # Duración máxima de canciones en minutos (por defecto: 8)

# Configuración de video (comando !video, opcional)
# Cuando VIDEO_ENABLED=true el bot acepta "!video <query>" además de !music.
# Las descargas de video son más pesadas, por eso el límite por defecto es menor
# y el flag está apagado salvo que se active explícitamente.
VIDEO_ENABLED = false       # true/false (por defecto: false)
MAX_VIDEO_DURATION = 5      # Duración máxima de videos en minutos (por defecto: 5)

# Configuración de cookies de YouTube (opcional)
# Ruta al archivo de cookies JSON para acceder a contenido restringido de YouTube
YOUTUBE_COOKIES_PATH = ./auth_info/youtube-cookies.json

# ── Conexión con el chat ────────────────────────────────────────────────────
# URL base del backend (sin barra final)
CHAT_API_URL = http://localhost:3001

# API Key generada desde el panel Admin → Bots para el usuario bot correspondiente
CHAT_API_KEY = your-api-key-here

# ── Persistencia ────────────────────────────────────────────────────────────
# El bot guarda memorias, logs y contexto en MongoDB. Puede compartir la DB
# del backend; las collections van con prefijo bot_* para no chocar.
MONGODB_URI = mongodb+srv://user:password@cluster.mongodb.net/chatapp?retryWrites=true&w=majority
